rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow anyone to read workspace logos, as the URL will be public anyway.
    match /workspaces/{workspaceId}/logo {
      allow read;
      
      // Allow write access only to the authenticated owner of the workspace.
      // As a safeguard, we also enforce that the uploaded file is an image and is less than 2MB.
      allow write: if request.auth != null &&
                    request.resource.size < 2 * 1024 * 1024 &&
                    request.resource.contentType.matches('image/.*') &&
                    firestore.get(/databases/(default)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid;
    }

    // Deny all other access to the bucket by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
