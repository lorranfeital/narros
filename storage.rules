rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow anyone to read workspace logos, as the URL will be public anyway.
    match /workspaces/{workspaceId}/logo {
      allow read;
      
      // Allow write access only if the 'ownerId' in the file metadata
      // matches the UID of the authenticated user. This is more robust than
      // a cross-service Firestore read.
      allow write: if request.auth != null &&
                    request.resource.size < 2 * 1024 * 1024 &&
                    request.resource.contentType.matches('image/.*') &&
                    request.resource.metadata.ownerId == request.auth.uid;
    }

    // Deny all other access to the bucket by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
