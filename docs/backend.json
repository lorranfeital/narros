
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user account in the Narros platform.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "plan": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "plan", "createdAt"]
    },
    "Workspace": {
      "title": "Workspace",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "logoUrl": { "type": "string", "format": "uri" },
        "type": { "type": "string", "enum": ["empresa", "grupo", "franquia", "rede", "loja", "clínica", "escritório", "outro"] },
        "sector": { "type": "string" },
        "ownerId": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["never_published", "draft_ready", "published", "sync_pending", "archived"] },
        "ingestionState": { "type": "string", "enum": ["idle", "ingesting", "processing"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "lastPublishedAt": { "type": "string", "format": "date-time" },
        "lastProcessedAt": { "type": "string", "format": "date-time" },
        "pendingSyncCount": { "type": "number" },
        "visibility": { "type": "string", "enum": ["public", "private"] }
      },
      "required": ["name", "type", "sector", "ownerId", "members", "status", "ingestionState", "createdAt"]
    },
    "Source": {
      "title": "Source",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["text", "file", "audio", "integration"] },
        "sourceName": { "type": "string" },
        "mimeType": { "type": "string" },
        "storagePath": { "type": "string" },
        "rawText": { "type": "string" },
        "extractedText": { "type": "string" },
        "transcript": { "type": "string" },
        "processingStatus": { "type": "string", "enum": ["pending", "processing", "completed", "error"] },
        "batchId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "notes": { "type": "string" }
      },
      "required": ["type", "processingStatus", "createdAt", "createdBy"]
    },
    "DraftKnowledge": {
        "title": "Draft Knowledge",
        "type": "object",
        "properties": {
            "categories": { "type": "array", "items": { "$ref": "#/backend/entities/KnowledgeCategory" }},
            "generatedAt": { "type": "string", "format": "date-time"},
            "sourceBatchId": { "type": "string" },
            "version": { "type": "number" },
            "status": { "type": "string", "enum": ["draft", "under_review"] }
        },
        "required": ["categories", "generatedAt", "sourceBatchId", "version", "status"]
    },
    "PublishedKnowledge": {
        "title": "Published Knowledge",
        "type": "object",
        "properties": {
            "categories": { "type": "array", "items": { "$ref": "#/backend/entities/KnowledgeCategory" }},
            "publishedAt": { "type": "string", "format": "date-time"},
            "version": { "type": "number" },
            "publishedBy": { "type": "string" }
        },
        "required": ["categories", "publishedAt", "version", "publishedBy"]
    },
    "KnowledgeCategory": {
        "title": "Knowledge Category",
        "type": "object",
        "properties": {
            "categoria": { "type": "string" },
            "icone": { "type": "string" },
            "itens": { "type": "array", "items": {
                "type": "object",
                "properties": {
                    "titulo": { "type": "string" },
                    "descricao": { "type": "string" }
                },
                "required": ["titulo", "descricao"]
            }}
        },
        "required": ["categoria", "itens"]
    },
    "Playbook": {
        "title": "Playbook",
        "type": "object",
        "properties": {
            "processo": { "type": "string" },
            "passos": { "type": "array", "items": {
                "type": "object",
                "properties": {
                    "numero": { "type": "number" },
                    "titulo": { "type": "string" },
                    "descricao": { "type": "string" }
                },
                "required": ["numero", "titulo", "descricao"]
            }},
            "sourceRefs": { "type": "array", "items": { "type": "string" }},
            "status": { "type": "string", "enum": ["draft", "published"] },
            "createdAt": { "type": "string", "format": "date-time" },
            "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["processo", "passos", "status", "createdAt"]
    },
    "TrainingModule": {
      "title": "Training Module",
      "type": "object",
      "properties": {
        "modulo": { "type": "number" },
        "titulo": { "type": "string" },
        "duracao": { "type": "string" },
        "objetivo": { "type": "string" },
        "topicos": { "type": "array", "items": { "type": "string" } },
        "formato": { "type": "string", "enum": ["presencial", "vídeo", "slides", "prático"] },
        "sourceRefs": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["draft", "published"] }
      },
      "required": ["modulo", "titulo", "objetivo", "formato", "status"]
    },
    "Insight": {
        "title": "Insight",
        "type": "object",
        "properties": {
            "texto": { "type": "string" },
            "tipo": { "type": "string", "enum": ["gap", "oportunidade", "risco"] },
            "sourceRefs": { "type": "array", "items": { "type": "string" }},
            "resolved": { "type": "boolean" },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["texto", "tipo", "resolved", "createdAt"]
    },
    "SyncProposal": {
      "title": "Sync Proposal",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["new", "updated", "conflict", "obsolete"] },
        "entityType": { "type": "string", "enum": ["knowledge", "playbook", "training"] },
        "entityId": { "type": "string" },
        "before": { "type": "object" },
        "after": { "type": "object" },
        "sourceBatchId": { "type": "string" },
        "approvalStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] }
      },
      "required": ["type", "entityType", "entityId", "sourceBatchId", "approvalStatus"]
    },
    "Version": {
      "title": "Version",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["initial_publish", "sync_publish", "manual_edit"] },
        "summary": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "version": { "type": "number" }
      },
      "required": ["type", "summary", "createdAt", "createdBy", "version"]
    },
    "AssistantThread": {
      "title": "Assistant Thread",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "createdAt", "createdBy"]
    },
    "AssistantMessage": {
      "title": "Assistant Message",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "citations": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "createdAt"]
    },
    "BrandKit": {
      "title": "Brand Kit",
      "type": "object",
      "properties": {
        "colorPalette": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "Nome da cor (ex: 'Primária', 'Acento')" },
              "hex": { "type": "string", "description": "Código hexadecimal da cor (ex: '#FF5733')" }
            },
            "required": ["name", "hex"]
          }
        },
        "typography": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "Uso da fonte (ex: 'Títulos', 'Corpo de texto')" },
              "family": { "type": "string", "description": "Nome da família da fonte (ex: 'Montserrat')" },
              "weight": { "type": "string", "description": "Peso da fonte (ex: '700', 'Bold')" }
            },
            "required": ["name", "family"]
          }
        },
        "toneOfVoice": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Lista de adjetivos ou frases que descrevem o tom de voz"
        },
        "sourceRefs": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": []
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com", "microsoft.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "schema": { "$ref": "#/backend/entities/User" } }
      },
      {
        "path": "/workspaces/{workspaceId}",
        "definition": { "schema": { "$ref": "#/backend/entities/Workspace" } }
      },
      {
        "path": "/workspaces/{workspaceId}/sources/{sourceId}",
        "definition": { "schema": { "$ref": "#/backend/entities/Source" } }
      },
      {
        "path": "/workspaces/{workspaceId}/draft_knowledge/{draftId}",
        "definition": { "schema": { "$ref": "#/backend/entities/DraftKnowledge" } }
      },
      {
        "path": "/workspaces/{workspaceId}/published_knowledge/{publishedId}",
        "definition": { "schema": { "$ref": "#/backend/entities/PublishedKnowledge" } }
      },
      {
        "path": "/workspaces/{workspaceId}/brand_kit/{brandKitId}",
        "definition": { "schema": { "$ref": "#/backend/entities/BrandKit" } }
      },
      {
        "path": "/workspaces/{workspaceId}/playbooks/{playbookId}",
        "definition": { "schema": { "$ref": "#/backend/entities/Playbook" } }
      },
      {
        "path": "/workspaces/{workspaceId}/training_modules/{moduleId}",
        "definition": { "schema": { "$ref": "#/backend/entities/TrainingModule" } }
      },
      {
        "path": "/workspaces/{workspaceId}/insights/{insightId}",
        "definition": { "schema": { "$ref": "#/backend/entities/Insight" } }
      },
      {
        "path": "/workspaces/{workspaceId}/sync_proposals/{proposalId}",
        "definition": { "schema": { "$ref": "#/backend/entities/SyncProposal" } }
      },
      {
        "path": "/workspaces/{workspaceId}/versions/{versionId}",
        "definition": { "schema": { "$ref": "#/backend/entities/Version" } }
      },
      {
        "path": "/workspaces/{workspaceId}/assistant_threads/{threadId}",
        "definition": { "schema": { "$ref": "#/backend/entities/AssistantThread" } }
      },
      {
        "path": "/workspaces/{workspaceId}/assistant_threads/{threadId}/messages/{messageId}",
        "definition": { "schema": { "$ref": "#/backend/entities/AssistantMessage" } }
      }
    ]
  }
}
